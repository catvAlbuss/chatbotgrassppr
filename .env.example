# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=sk-proj-AQUI_TU_NUEVA_API_KEY

# ============================================
# META / WHATSAPP BUSINESS API
# ============================================
# Token del Sistema (System User Token) con permiso whatsapp_business_management
# Obtenerlo en: business.facebook.com → Configuración → Usuarios del sistema
WHATSAPP_TOKEN=AQUI_TU_SYSTEM_USER_TOKEN

# ID del número de teléfono por defecto (tu número demo)
PHONE_NUMBER_ID=AQUI_TU_PHONE_NUMBER_ID

# ID de tu cuenta de WhatsApp Business (WABA)
# Obtenerlo en: business.facebook.com → Configuración de WhatsApp
# Necesario para el flujo de "verificar registro" de clientes
WABA_ID=AQUI_TU_WABA_ID

VERIFY_TOKEN=gespro_asist_2026

# ============================================
# NÚMERO DEL ADMINISTRADOR
# (quien aprueba/rechaza pagos)
# Formato: 51 + número sin espacios
# ============================================
ADMIN_PHONE=51999999999

# ============================================
# NÚMERO DE CONTACTO PÚBLICO (landing y planes)
# Formato: 51 + número sin espacios ni +
# ============================================
CONTACT_PHONE=51999999999
VITE_CONTACT_PHONE=51999999999

# ============================================
# DATOS DE PAGO
# ============================================
PAYMENT_YAPE=999999999
PAYMENT_PLIN=999999999
PAYMENT_ACCOUNT=Grass Sintético SAC

# ============================================
# SERVIDOR
# ============================================
PORT=3000

# ============================================
# DASHBOARD DE ADMINISTRACIÓN
# Accede en: https://tu-dominio.com/admin
# ============================================
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambia_esta_clave_segura
DASHBOARD_SECRET=gespro_asist_clave_jwt_secreta_larga_y_random

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gespro_asist

# ============================================
# QR PÚBLICO
# ============================================
QR_PUBLIC_URL=https://tu-dominio.com

# ============================================
# RENIEC (opcional)
# ============================================
RENIEC_API_TOKEN=

